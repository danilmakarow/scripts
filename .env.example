PROJECTS_DIR=/Users/yourname/projects

# Optional: dir name created under ~/.local/bin/ by `pnpm run pack`.
# Defaults to "custom_scripts" if unset.
SCRIPTS_PACK_DIR=custom_scripts

# Required for do-commit / do-checkout / do-mr (Claude Haiku).
ANTHROPIC_API_KEY=

# Required for do-mr (GitLab/GitHub API access).
GIT_ACCESS_TOKEN=
