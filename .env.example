PROJECTS_DIR=/Users/yourname/projects

# Optional: dir name created under $TMPDIR by `pnpm run pack`.
# Defaults to "custom-scripts" if unset.
SCRIPTS_PACK_DIR=custom-scripts

# Required for do-commit / do-checkout / do-mr (Claude Haiku).
ANTHROPIC_API_KEY=

# Required for do-mr (GitLab/GitHub API access).
GIT_ACCESS_TOKEN=
